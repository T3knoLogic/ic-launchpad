  "defaults": { "build": { "packtool": "", "args": "" } },
  "output_env_file": ".env",
  "networks": {
    "local": { "bind": "0.0.0.0:4943" },
    "ic": { "providers": ["https://mainnet.dfinity.network"], "type": "persistent" }
  }
