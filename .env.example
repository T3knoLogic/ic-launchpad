# After `dfx deploy`, copy .env here and use in frontend.
# Frontend (Vite) expects VITE_ prefixed vars.
VITE_LAUNCHPAD_WALLET_CANISTER_ID=
VITE_LAUNCHPAD_REGISTRY_CANISTER_ID=

# Integrations canister (linked accounts)
VITE_LAUNCHPAD_INTEGRATIONS_CANISTER_ID=

# Milady AI (after: bash scripts/build-milady-for-icp.sh && dfx deploy milady_launchpad --network ic)
VITE_MILADY_CANISTER_ID=

# Google sign-in for Integrations page (create at https://console.cloud.google.com/apis/credentials)
# VITE_GOOGLE_CLIENT_ID=

# Auth backend URL for GitHub/Discord OAuth (default http://localhost:3030). Run: npm run auth:dev
# VITE_AUTH_BACKEND_URL=http://localhost:3030

# Optional – for local testing:
# VITE_II_CANISTER_ID=<local II canister id>   (if you deploy II locally)
# VITE_USE_MAINNET_II=true                     (use mainnet II when running npm run dev)

# MCP / CLI (optional)
LAUNCHPAD_WALLET_CANISTER_ID=
LAUNCHPAD_REGISTRY_CANISTER_ID=
DFX_NETWORK=ic
